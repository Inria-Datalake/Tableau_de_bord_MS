import React, { useState, useEffect, useMemo, useRef } from 'react';
import { base44 } from '@/api/base44Client';
import {
  FileText, Globe, Building2, Users, Sun, Moon, BarChart2, Map, Download, Loader2,
  CalendarRange, FlaskConical, Layers, UserCheck, Percent, Network
} from 'lucide-react';

import FilterSidebar from '@/components/dashboard/FilterSidebar';
import StatCard from '@/components/dashboard/StatCard';
import ChartCard from '@/components/dashboard/ChartCard';
import PublicationsByYear from '@/components/charts/PublicationsByYear';
import HorizontalBarChart from '@/components/charts/HorizontalBarChart';
import DonutChart from '@/components/charts/DonutChart';
import VerticalBarChart from '@/components/charts/VerticalBarChart';
import WordCloud from '@/components/charts/WordCloud';
import NetworkGraph from '@/components/charts/NetworkGraph';
import ChoroplethMap from '@/components/charts/ChoroplethMap';
import RadarChartDomaines from '@/components/charts/RadarChartDomaines';

import {
  applyFilters, getPublicationsByYear, getTopCountries, getTopOrganismes,
  getEUDistribution, getDocTypeDistribution, getTopEquipes, getCentreDistribution,
  getKeywords, getNetworkData, getMapData, getFilterOptions, getTopCities, getDomainesDistribution
} from '@/lib/dataProcessor';

const TABS = [
  { id: 'overview', label: 'Vue d\'ensemble', icon: BarChart2 },
  { id: 'exploration', label: 'Carte & Réseau', icon: Map },
];

export default function Dashboard() {
  const [darkMode, setDarkMode] = useState(true);
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);
  const [activeTab, setActiveTab] = useState('overview');
  const [rawData, setRawData] = useState([]);
  const [loading, setLoading] = useState(true);
  const [filters, setFilters] = useState({
    centre: '', pays: '', equipe: '', auteur: '',
    docType: '', domaine: '', anneeMin: null, anneeMax: null
  });

  // Apply dark mode
  useEffect(() => {
    if (darkMode) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }, [darkMode]);

  // Fetch all data with pagination
  useEffect(() => {
    async function loadData() {
      setLoading(true);
      try {
        let allData = [];
        let page = 0;
        const pageSize = 500;
        let hasMore = true;
        while (hasMore) {
          const batch = await base44.entities.Publication.list('-annee', pageSize, pageSize * page);
          allData = [...allData, ...batch];
          hasMore = batch.length === pageSize;
          page++;
          if (page > 10) break; // safety
        }
        setRawData(allData);
      } catch (e) {
        console.error(e);
      } finally {
        setLoading(false);
      }
    }
    loadData();
  }, []);

  const filteredData = useMemo(() => applyFilters(rawData, filters), [rawData, filters]);
  const filterOptions = useMemo(() => getFilterOptions(rawData), [rawData]);

  // Computed chart data
  const byYear = useMemo(() => getPublicationsByYear(filteredData), [filteredData]);
  const topCountries = useMemo(() => getTopCountries(filteredData, 10), [filteredData]);
  const topCities = useMemo(() => getTopCities(filteredData, 10), [filteredData]);
  const topOrgs = useMemo(() => getTopOrganismes(filteredData, 10), [filteredData]);
  const euDist = useMemo(() => getEUDistribution(filteredData), [filteredData]);
  const docTypes = useMemo(() => getDocTypeDistribution(filteredData), [filteredData]);
  const topEquipes = useMemo(() => getTopEquipes(filteredData, 15), [filteredData]);
  const centres = useMemo(() => getCentreDistribution(filteredData), [filteredData]);
  const keywords = useMemo(() => getKeywords(filteredData), [filteredData]);
  const networkData = useMemo(() => getNetworkData(filteredData), [filteredData]);
  const mapData = useMemo(() => getMapData(filteredData), [filteredData]);
  const domaines = useMemo(() => getDomainesDistribution(filteredData), [filteredData]);

  const uniquePublications = useMemo(() => new Set(filteredData.map(d => d.hal_id)).size, [filteredData]);
  const uniqueCountries = useMemo(() => new Set(filteredData.map(d => d.nom_pays).filter(Boolean)).size, [filteredData]);
  const uniqueOrgs = useMemo(() => new Set(filteredData.map(d => d.nom_org_top_copubliant).filter(Boolean)).size, [filteredData]);
  const uniqueAuthors = useMemo(() => new Set(filteredData.map(d => d.auteur_inria).filter(Boolean)).size, [filteredData]);

  // Indicateurs secondaires dérivés des colonnes
  const uniqueEquipes = useMemo(() => new Set(filteredData.map(d => d.equipe_inria).filter(Boolean)).size, [filteredData]);
  const uniqueDocTypes = useMemo(() => new Set(filteredData.map(d => d.doc_type).filter(Boolean)).size, [filteredData]);
  const uniqueDomainesInria = useMemo(() => new Set(filteredData.map(d => d.domaine_inria).filter(Boolean)).size, [filteredData]);
  const uniqueCoauthors = useMemo(() => new Set(filteredData.map(d => d.auteur_coauteur).filter(Boolean)).size, [filteredData]);
  const yearsRange = useMemo(() => {
    const years = filteredData.map(d => d.annee).filter(Boolean);
    if (!years.length) return '–';
    return `${Math.min(...years)}–${Math.max(...years)}`;
  }, [filteredData]);
  const pctUE = useMemo(() => {
    const withUE = filteredData.filter(d => d.ue_hors_ue);
    if (!withUE.length) return '–';
    const ue = withUE.filter(d => d.ue_hors_ue === 'UE').length;
    return `${Math.round((ue / withUE.length) * 100)} %`;
  }, [filteredData]);

  const [exporting, setExporting] = useState(false);
  const mainRef = useRef(null);

  const handleExportPDF = async () => {
    setExporting(true);
    try {
      const html2canvas = (await import('html2canvas')).default;
      const { jsPDF } = await import('jspdf');

      const element = mainRef.current;
      const canvas = await html2canvas(element, {
        scale: 1.5,
        useCORS: true,
        backgroundColor: darkMode ? '#0b1222' : '#f4f6fb',
        logging: false,
      });

      const imgData = canvas.toDataURL('image/png');
      const pdf = new jsPDF({ orientation: 'landscape', unit: 'px', format: [canvas.width / 1.5, canvas.height / 1.5] });
      pdf.addImage(imgData, 'PNG', 0, 0, canvas.width / 1.5, canvas.height / 1.5);

      const tabLabel = activeTab === 'overview' ? 'Vue-ensemble' : 'Carte-Reseau';
      const date = new Date().toISOString().slice(0, 10);
      pdf.save(`Copublications-Inria_${tabLabel}_${date}.pdf`);
    } catch (e) {
      console.error(e);
    } finally {
      setExporting(false);
    }
  };

  const handleFilterChange = (key, value) => setFilters(prev => ({ ...prev, [key]: value }));
  const clearAllFilters = () => setFilters({ centre: '', pays: '', equipe: '', auteur: '', docType: '', domaine: '', anneeMin: null, anneeMax: null });

  return (
    <div className={`flex flex-col h-screen bg-background overflow-hidden`}>
      {/* Top Header */}
      <header className="flex-shrink-0 flex items-center justify-between px-5 py-3 border-b border-border bg-card z-50 shadow-sm">
        <div className="flex items-center gap-3">
          {/* DataLake Logo */}
          <div className="flex items-center gap-2">
            <img
              src="https://media.base44.com/images/public/6a268815996e6a1f77a171ba/1923b3bd2_image.png"
              alt="DataLake Logo"
              className="h-10 w-auto object-contain"
            />
          </div>
          <div className="hidden md:block w-px h-8 bg-border mx-1" />
          <div className="hidden md:flex flex-col">
            <span className="text-sm font-bold text-foreground">Copublications Inria</span>
            <span className="text-[10px] text-muted-foreground">Analyse scientométrique 2001–2024</span>
          </div>
        </div>

        {/* Tabs */}
        <div className="flex items-center gap-1 bg-muted rounded-lg p-0.5">
          {TABS.map(tab => {
            const Icon = tab.icon;
            return (
              <button
                key={tab.id}
                onClick={() => setActiveTab(tab.id)}
                className={`flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-semibold transition-all ${
                  activeTab === tab.id
                    ? 'bg-card text-foreground shadow-sm'
                    : 'text-muted-foreground hover:text-foreground'
                }`}
              >
                <Icon className="h-3.5 w-3.5" />
                <span className="hidden sm:block">{tab.label}</span>
              </button>
            );
          })}
        </div>

        {/* Dark mode + stats + export */}
        <div className="flex items-center gap-2">
          <span className="hidden lg:flex items-center gap-1.5 text-xs text-muted-foreground bg-muted rounded-full px-3 py-1">
            <span className="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" />
            {filteredData.length.toLocaleString()} lignes
          </span>
          <button
            onClick={handleExportPDF}
            disabled={exporting || loading}
            title="Exporter en PDF"
            className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-primary/10 hover:bg-primary/20 text-primary text-xs font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            {exporting ? <Loader2 className="h-4 w-4 animate-spin" /> : <Download className="h-4 w-4" />}
            <span className="hidden sm:block">{exporting ? 'Export...' : 'Export PDF'}</span>
          </button>
          <button
            onClick={() => setDarkMode(!darkMode)}
            className="p-2 rounded-lg bg-muted hover:bg-primary/20 transition-colors"
          >
            {darkMode ? <Sun className="h-4 w-4 text-amber-400" /> : <Moon className="h-4 w-4 text-blue-400" />}
          </button>
        </div>
      </header>

      {/* Main Content */}
      <div className="flex flex-1 overflow-hidden">
        {/* Sidebar */}
        <aside className={`flex-shrink-0 border-r border-border bg-card/80 backdrop-blur transition-all duration-300 ${sidebarCollapsed ? 'w-12' : 'w-56'} overflow-hidden`}>
          <FilterSidebar
            filters={filters}
            filterOptions={filterOptions}
            onFilterChange={handleFilterChange}
            onClearAll={clearAllFilters}
            collapsed={sidebarCollapsed}
            onToggle={() => setSidebarCollapsed(!sidebarCollapsed)}
          />
        </aside>

        {/* Dashboard content */}
        <main ref={mainRef} className="flex-1 overflow-y-auto p-4">
          {loading ? (
            <div className="flex h-full items-center justify-center">
              <div className="flex flex-col items-center gap-3">
                <div className="w-10 h-10 border-4 border-primary/30 border-t-primary rounded-full animate-spin" />
                <p className="text-sm text-muted-foreground">Chargement des données...</p>
              </div>
            </div>
          ) : (
            <>
              {/* KPI Cards — Rangée 1 : indicateurs principaux */}
              <div className="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-3">
                <StatCard title="Publications uniques" value={uniquePublications.toLocaleString()} subtitle={`${filteredData.length.toLocaleString()} lignes totales`} icon={FileText} color="blue" />
                <StatCard title="Pays partenaires" value={uniqueCountries} subtitle="dans le monde" icon={Globe} color="purple" />
                <StatCard title="Organismes" value={uniqueOrgs.toLocaleString()} subtitle="partenaires uniques" icon={Building2} color="green" />
                <StatCard title="Auteurs Inria" value={uniqueAuthors.toLocaleString()} subtitle="chercheurs actifs" icon={Users} color="orange" />
              </div>

              {/* KPI Cards — Rangée 2 : indicateurs dérivés */}
              <div className="grid grid-cols-2 lg:grid-cols-6 gap-3 mb-4">
                <StatCard title="Équipes Inria" value={uniqueEquipes} subtitle="équipes actives" icon={Network} color="cyan" />
                <StatCard title="Co-auteurs ext." value={uniqueCoauthors.toLocaleString()} subtitle="co-auteurs distincts" icon={UserCheck} color="purple" />
                <StatCard title="Types de docs" value={uniqueDocTypes} subtitle="catégories distinctes" icon={Layers} color="blue" />
                <StatCard title="Domaines Inria" value={uniqueDomainesInria} subtitle="thématiques" icon={FlaskConical} color="green" />
                <StatCard title="Période couverte" value={yearsRange} subtitle="années d'analyse" icon={CalendarRange} color="orange" />
                <StatCard title="Part UE" value={pctUE} subtitle="copublications UE" icon={Percent} color="cyan" />
              </div>

              {/* TAB 1: Overview */}
              {activeTab === 'overview' && (
                <div className="space-y-4">
                  {/* Publications by year - full width */}
                  <ChartCard title="📈 Copublications par année" subtitle="Évolution temporelle" className="h-64">
                    <PublicationsByYear data={byYear} />
                  </ChartCard>

                  {/* Row 1: Top 10 Pays + Top 10 Villes */}
                  <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <ChartCard title="🌍 Top 10 Pays copubliants" subtitle="Par nombre de copublications" className="h-80">
                      <HorizontalBarChart data={topCountries} />
                    </ChartCard>
                    <ChartCard title="🏙️ Top 10 Villes copubliantes" subtitle="Extraites des adresses" className="h-80">
                      <HorizontalBarChart data={topCities} color="hsl(262, 83%, 68%)" />
                    </ChartCard>
                  </div>

                  {/* Row 2: Top 10 Organismes + UE/Hors UE */}
                  <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <ChartCard title="🏛️ Top 10 Organismes copubliants" subtitle="Organisations partenaires principales" className="h-80">
                      <HorizontalBarChart data={topOrgs} color="hsl(142, 71%, 55%)" />
                    </ChartCard>
                    <ChartCard title="🇪🇺 Répartition UE / Hors UE" subtitle="Distribution géographique européenne" className="h-80">
                      <DonutChart data={euDist} innerRadius={55} />
                    </ChartCard>
                  </div>

                  {/* Row 3: Types de documents + Domaines Inria */}
                  <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <ChartCard title="📄 Types de documents" subtitle="Répartition par catégorie" className="h-72">
                      <DonutChart data={docTypes.slice(0, 8).map((d, i) => ({ ...d, value: d.value }))} innerRadius={45} />
                    </ChartCard>
                    <ChartCard title="🔬 Domaines Inria" subtitle="Couverture thématique" className="h-72">
                      <RadarChartDomaines data={domaines} />
                    </ChartCard>
                  </div>

                  {/* Row 4: Centres Inria */}
                  <ChartCard title="🏢 Copublications par Centre Inria" subtitle="Volume par entité géographique" className="h-72">
                    <VerticalBarChart data={centres} dataKey="count" nameKey="name" />
                  </ChartCard>
                </div>
              )}

              {/* TAB 2: Exploration */}
              {activeTab === 'exploration' && (
                <div className="space-y-4">
                  {/* World Map */}
                  <ChartCard
                    title="🗺️ Carte mondiale des copublications"
                    subtitle="Cliquez sur un pays pour voir le détail · Coloration proportionnelle au volume"
                    className="h-[520px]"
                  >
                    <ChoroplethMap data={mapData} darkMode={darkMode} />
                  </ChartCard>

                  {/* Network + Word Cloud side by side */}
                  <div className="grid grid-cols-1 xl:grid-cols-2 gap-4">
                    <ChartCard
                      title="🕸️ Réseau de copublication"
                      subtitle="Centres Inria → Organismes partenaires"
                      className="h-[420px]"
                    >
                      <NetworkGraph data={networkData} />
                    </ChartCard>
                    <ChartCard
                      title="☁️ Nuage de mots-clés"
                      subtitle="Termes scientifiques les plus fréquents"
                      className="h-[420px]"
                    >
                      <WordCloud data={keywords} />
                    </ChartCard>
                  </div>

                  {/* Top 15 Equipes + Centres */}
                  <div className="grid grid-cols-1 xl:grid-cols-2 gap-4">
                    <ChartCard
                      title="👥 Top 15 Équipes Inria"
                      subtitle="Équipes les plus actives en copublication"
                      className="h-96"
                    >
                      <HorizontalBarChart data={topEquipes} color="hsl(38, 92%, 60%)" />
                    </ChartCard>
                    <ChartCard
                      title="🏢 Copublications par Centre Inria"
                      subtitle="Distribution par entité géographique"
                      className="h-96"
                    >
                      <VerticalBarChart data={centres} dataKey="count" nameKey="name" />
                    </ChartCard>
                  </div>
                </div>
              )}
            </>
          )}
        </main>
      </div>

      {/* Footer */}
      <footer className="flex-shrink-0 border-t border-border bg-card/80 px-5 py-2.5 flex items-center justify-between">
        <div className="flex items-center gap-2">
          <img
            src="https://media.base44.com/images/public/6a268815996e6a1f77a171ba/1923b3bd2_image.png"
            alt="DataLake Logo"
            className="h-7 w-auto object-contain"
          />
          <span className="text-xs text-muted-foreground">DataLake • Dashboard Copublications Inria</span>
        </div>
        <div className="flex items-center gap-3">
          <span className="text-xs text-muted-foreground hidden sm:block">
            Données : HAL / Inria · {new Set(rawData.map(d => d.annee).filter(Boolean)).size} années
          </span>
          <div className="h-4 w-px bg-border hidden sm:block" />
          <span className="text-xs font-medium text-foreground">
            Créé par{' '}
            <span className="text-primary font-semibold">Andréa NEBOT</span>
            {' '}· Data Analyst - INRIA
          </span>
        </div>
      </footer>
    </div>
  );
}