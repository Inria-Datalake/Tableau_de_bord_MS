function extractCityFromAddress(addr) {
  if (!addr) return null;

  // Strategy 1: match French postal code pattern "XXXXX CityName"
  const postalMatch = addr.match(/\b\d{5}\s+([A-ZÀ-Ÿa-zà-ÿ][A-ZÀ-Ÿa-zà-ÿ\s\-]+?)(?:\s*(?:Cedex[\s\d]*|\.|,|$))/i);
  if (postalMatch) {
    return postalMatch[1].trim();
  }

  // Strategy 2: last comma-separated segment that looks like a city
  const parts = addr.split(/[,\n]/);
  for (let i = parts.length - 1; i >= 0; i--) {
    const p = parts[i].trim()
      .replace(/cedex\s*\d*/gi, '')
      .replace(/\b\d{4,}\b/g, '')
      .replace(/bp\s*\d+/gi, '')
      .trim();
    if (p.length >= 2 && p.length <= 40 && !/^\d+$/.test(p) && !/^(rue|avenue|place|boulevard|allée|chemin|impasse|bâtiment|bat\b)/i.test(p)) {
      return p;
    }
  }
  return null;
}

export function getTopCities(data, limit = 10) {
  const cities = {};
  data.forEach(d => {
    const raw = extractCityFromAddress(d.adresse_org_copubliant);
    if (!raw) return;

    let city = normalizeCityName(raw);
    // Apply alias merging
    city = CITY_ALIASES[city] || city;
    // Skip noise
    if (city.length < 2 || city.length > 50) return;

    cities[city] = (cities[city] || 0) + 1;
  });

  return Object.entries(cities)
    .map(([name, count]) => ({ name, count }))
    .sort((a, b) => b.count - a.count)
    .slice(0, limit);
}

export function getDomainesDistribution(data) {
  const counts = _.countBy(data.filter(d => d.domaine_inria), 'domaine_inria');
  return Object.entries(counts)
    .map(([name, count]) => ({ name: name.length > 35 ? name.slice(0, 32) + '...' : name, fullName: name, count }))
    .sort((a, b) => b.count - a.count)
    .slice(0, 8);
}