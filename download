export function normalizeCentre(raw) {
  if (!raw) return raw;
  return CENTRE_ALIASES[raw.trim()] || raw.trim();
}

export function processRawData(publications) {
  return publications.map(p => ({
    hal_id: p.hal_id || '',
    doc_type: p.doc_type || '',
    annee: p.annee || 0,
    centre_inria: p.centre_inria || '',
    equipe_inria: p.equipe_inria || '',
    auteur_inria: p.auteur_inria || '',
    auteur_coauteur: p.auteur_coauteur || '',
    nom_org_copubliant: p.nom_org_copubliant || '',
    adresse_org_copubliant: p.adresse_org_copubliant || '',
    nom_org_top_copubliant: p.nom_org_top_copubliant || '',
    code_pays: p.code_pays || '',
    nom_pays: p.nom_pays || '',
    ue_hors_ue: p.ue_hors_ue || '',
    domaine_hal: p.domaine_hal || '',
    mots_cles_hal: p.mots_cles_hal || '',
    domaine_inria: p.domaine_inria || '',
    mots_cles_inria: p.mots_cles_inria || '',
  }));
}

export function applyFilters(data, filters) {
  return data.filter(d => {
    if (filters.centre && normalizeCentre(d.centre_inria) !== filters.centre) return false;
    if (filters.pays && d.nom_pays !== filters.pays) return false;
    if (filters.anneeMin && d.annee < filters.anneeMin) return false;
    if (filters.anneeMax && d.annee > filters.anneeMax) return false;
    if (filters.equipe && d.equipe_inria !== filters.equipe) return false;
    if (filters.auteur && d.auteur_inria !== filters.auteur) return false;
    if (filters.docType && d.doc_type !== filters.docType) return false;
    if (filters.domaine && d.domaine_inria !== filters.domaine) return false;
    return true;
  });
}

export function getPublicationsByYear(data) {
  const grouped = _.groupBy(data, 'annee');
  return Object.entries(grouped)
    .map(([year, items]) => ({ year: Number(year), count: items.length }))
    .sort((a, b) => a.year - b.year)
    .filter(d => d.year > 0);
}

export function getTopCountries(data, limit = 10) {
  const counts = _.countBy(data.filter(d => d.nom_pays), 'nom_pays');
  return Object.entries(counts)
    .map(([name, count]) => ({ name, count }))
    .sort((a, b) => b.count - a.count)
    .slice(0, limit);
}

export function getTopOrganismes(data, limit = 10) {
  const counts = _.countBy(data.filter(d => d.nom_org_top_copubliant), 'nom_org_top_copubliant');
  return Object.entries(counts)
    .map(([name, count]) => ({ name: name.length > 40 ? name.slice(0, 37) + '...' : name, fullName: name, count }))
    .sort((a, b) => b.count - a.count)
    .slice(0, limit);
}

export function getEUDistribution(data) {
  const counts = _.countBy(data.filter(d => d.ue_hors_ue), 'ue_hors_ue');
  return Object.entries(counts).map(([name, value]) => ({
    name: name === 'UE' ? 'Union Européenne' : 'Hors UE',
    value,
    fill: name === 'UE' ? 'hsl(var(--chart-1))' : 'hsl(var(--chart-2))'
  }));
}

export function getDocTypeDistribution(data) {
  const TYPE_LABELS = {
    ART: 'Article', COMM: 'Communication', POSTER: 'Poster', PRESCONF: 'Présentation',
    COUV: 'Chapitre', OUV: 'Ouvrage', THESE: 'Thèse', HDR: 'HDR',
    REPORT: 'Rapport', UNDEFINED: 'Non défini', PATENT: 'Brevet'
  };
  const counts = _.countBy(data.filter(d => d.doc_type), 'doc_type');
  return Object.entries(counts)
    .map(([name, value]) => ({ name: TYPE_LABELS[name] || name, value }))
    .sort((a, b) => b.value - a.value);
}

export function getTopEquipes(data, limit = 15) {
  const counts = _.countBy(data.filter(d => d.equipe_inria), 'equipe_inria');
  return Object.entries(counts)
    .map(([name, count]) => ({ name, count }))
    .sort((a, b) => b.count - a.count)
    .slice(0, limit);
}

export function getCentreDistribution(data) {
  const counts = {};
  data.forEach(d => {
    if (!d.centre_inria) return;
    const normalized = normalizeCentre(d.centre_inria);
    counts[normalized] = (counts[normalized] || 0) + 1;
  });
  return Object.entries(counts)
    .map(([name, count]) => ({ name: name.replace('Inria ', ''), fullName: name, count }))
    .sort((a, b) => b.count - a.count);
}

export function getKeywords(data) {
  const allKeywords = {};
  data.forEach(d => {
    const kw1 = (d.mots_cles_hal || '').split(';');
    const kw2 = (d.mots_cles_inria || '').split(',');
    [...kw1, ...kw2].forEach(k => {
      const clean = k.trim().toLowerCase();
      if (clean && clean.length > 2 && clean.length < 40) {
        allKeywords[clean] = (allKeywords[clean] || 0) + 1;
      }
    });
  });
  return Object.entries(allKeywords)
    .map(([text, value]) => ({ text, value }))
    .sort((a, b) => b.value - a.value)
    .slice(0, 80);
}

export function getNetworkData(data) {
  const links = {};
  data.forEach(d => {
    if (d.centre_inria && d.nom_org_top_copubliant) {
      const key = `${d.centre_inria}|||${d.nom_org_top_copubliant}`;
      links[key] = (links[key] || 0) + 1;
    }
  });
  return Object.entries(links)
    .map(([key, value]) => {
      const [source, target] = key.split('|||');
      return { source, target: target.length > 30 ? target.slice(0, 27) + '...' : target, value };
    })
    .sort((a, b) => b.value - a.value)
    .slice(0, 25);
}

export function getMapData(data) {
  const byCountry = {};
  data.forEach(d => {
    if (d.code_pays && COUNTRY_COORDS[d.code_pays]) {
      if (!byCountry[d.code_pays]) {
        byCountry[d.code_pays] = {
          code: d.code_pays,
          name: d.nom_pays,
          count: 0,
          coords: COUNTRY_COORDS[d.code_pays]
        };
      }
      byCountry[d.code_pays].count++;
    }
  });
  return Object.values(byCountry).sort((a, b) => b.count - a.count);
}

export function getFilterOptions(data) {
  return {
    centres: _.uniq(data.map(d => normalizeCentre(d.centre_inria)).filter(Boolean)).sort(),
    pays: _.uniq(data.map(d => d.nom_pays).filter(Boolean)).sort(),
    equipes: _.uniq(data.map(d => d.equipe_inria).filter(Boolean)).sort(),
    auteurs: _.uniq(data.map(d => d.auteur_inria).filter(Boolean)).sort(),
    docTypes: _.uniq(data.map(d => d.doc_type).filter(Boolean)).sort(),
    domaines: _.uniq(data.map(d => d.domaine_inria).filter(Boolean)).sort(),
    annees: _.uniq(data.map(d => d.annee).filter(Boolean)).sort(),
  };
}

// Normalize a city name: Title Case, remove accents variations, trim
function normalizeCityName(raw) {
  return raw
    .trim()
    .replace(/\s+/g, ' ')
    .toLowerCase()
    .replace(/\b\w/g, c => c.toUpperCase()); // Title Case
}

